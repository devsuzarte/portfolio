---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/#about',      label: 'Sobre'      },
  { href: '/#skills',     label: 'Stack'      },
  { href: '/#experience', label: 'Experiência'},
  { href: '/#projects',   label: 'Projetos'   },
  { href: '/#contact',    label: 'Contato'    },
];

const socialLinks = [
  { href: 'https://github.com/devsuzarte',            label: 'GitHub'   },
  { href: 'https://linkedin.com/in/benjamin-suzarte',  label: 'LinkedIn' },
  { href: 'mailto:devsuzarte@gmail.com',               label: 'E-mail'   },
];
---

<footer class="footer" data-theme="dark">
  <div class="footer__divider" aria-hidden="true"></div>

  <div class="container footer__inner">
    <!-- Brand -->
    <div class="footer__brand">
      <span class="footer__logo">devsuzarte</span>
      <p class="footer__tagline">Criando experiências web de alto padrão.</p>
      <p class="footer__built">
        Feito com <span class="footer__heart">♥</span> usando Astro + GSAP + Three.js
      </p>
    </div>

    <!-- Nav -->
    <nav class="footer__nav" aria-label="Navegação do footer">
      <p class="footer__nav-heading">Navegação</p>
      <ul class="footer__nav-list" role="list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="footer__nav-link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Social -->
    <div class="footer__social-col">
      <p class="footer__nav-heading">Contato</p>
      <ul class="footer__social-list" role="list">
        {socialLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="footer__social-link"
              target={link.href.startsWith('mailto') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            >
              {link.label}
              <span class="footer__arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">&copy; {currentYear} Juan Benjamin Almeida Suzarte</p>
      <p class="footer__legal">Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style lang="scss">
  @use '@/styles/tokens' as *;

  .footer {
    background: $espresso;
    position: relative;

    &__divider {
      height: 1px;
      background: linear-gradient(
        to right,
        transparent 0%,
        rgba($caramel, 0.35) 30%,
        rgba($amber, 0.5) 50%,
        rgba($caramel, 0.35) 70%,
        transparent 100%
      );
    }

    &__inner {
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
      padding-top: 3.5rem;
      padding-bottom: 3rem;

      @include respond-to(md) {
        grid-template-columns: 1.6fr 1fr 1fr;
        gap: 4rem;
      }
    }

    &__brand {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    &__logo {
      font-family: $font-display;
      font-weight: 600;
      font-size: 1.5rem;
      font-style: italic;
      color: $cream;
      letter-spacing: -0.01em;
    }

    &__tagline {
      font-family: $font-body;
      font-size: 0.9375rem;
      color: rgba($oat, 0.65);
      margin-bottom: 0.5rem;
    }

    &__built {
      font-family: $font-body;
      font-size: 0.75rem;
      color: $muted;
    }

    &__heart {
      color: $caramel;
      font-size: 0.8rem;
    }

    &__nav-heading {
      font-family: $font-sans;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba($oat, 0.35);
      margin-bottom: 1.25rem;
    }

    &__nav-list,
    &__social-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
    }

    &__nav-link {
      font-family: $font-body;
      font-size: 0.9375rem;
      color: rgba($oat, 0.65);
      text-decoration: none;
      transition: color $transition-base;

      &:hover { color: $cream; }
    }

    &__social-col {}

    &__social-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-family: $font-body;
      font-size: 0.9375rem;
      color: rgba($oat, 0.65);
      text-decoration: none;
      transition: color $transition-base;

      &:hover {
        color: $latte;

        .footer__arrow { opacity: 1; }
      }
    }

    &__arrow {
      font-size: 0.7rem;
      opacity: 0.4;
      transition: opacity $transition-base;
    }

    &__bottom {
      border-top: 1px solid rgba($oat, 0.07);
    }

    &__bottom-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
      padding-top: 1.25rem;
      padding-bottom: 1.5rem;
      text-align: center;

      @include respond-to(md) {
        flex-direction: row;
        justify-content: space-between;
        text-align: left;
      }
    }

    &__copy,
    &__legal {
      font-family: $font-body;
      font-size: 0.8125rem;
      color: $muted;
    }
  }
</style>
