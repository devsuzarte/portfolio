---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const allSkills = await getCollection('skills');

const ICON_MAP: Record<string, { icon: string; color: string }> = {
  'Figma':          { icon: 'simple-icons:figma',               color: '#F24E1E' },
  'Photoshop':      { icon: 'simple-icons:adobephotoshop',      color: '#31A8FF' },
  'React':          { icon: 'simple-icons:react',               color: '#61DAFB' },
  'TypeScript':     { icon: 'simple-icons:typescript',          color: '#3178C6' },
  'JavaScript':     { icon: 'simple-icons:javascript',          color: '#F7DF1E' },
  'HTML':           { icon: 'simple-icons:html5',               color: '#E34F26' },
  'CSS':            { icon: 'simple-icons:css3',                color: '#1572B6' },
  'Next.js':        { icon: 'simple-icons:nextdotjs',           color: '#ffffff' },
  'Three.js':       { icon: 'simple-icons:threedotjs',          color: '#ffffff' },
  'GSAP':           { icon: 'simple-icons:greensock',           color: '#88CE02' },
  'Leaflet':        { icon: 'simple-icons:leaflet',             color: '#199900' },
  'Astro':          { icon: 'simple-icons:astro',               color: '#FF5D01' },
  'Barba.js':       { icon: 'simple-icons:javascript',          color: '#B04020' },
  'Node.js':        { icon: 'simple-icons:nodedotjs',           color: '#5FA04E' },
  'Python':         { icon: 'simple-icons:python',              color: '#3776AB' },
  'NestJS':         { icon: 'simple-icons:nestjs',              color: '#E0234E' },
  'PrismaORM':      { icon: 'simple-icons:prisma',              color: '#5A67D8' },
  'TypeORM':        { icon: 'simple-icons:typeorm',             color: '#FE0803' },
  'GraphQL':        { icon: 'simple-icons:graphql',             color: '#E10098' },
  'Claude Code':    { icon: 'simple-icons:anthropic',           color: '#D4A27F' },
  'OpenAI':         { icon: 'simple-icons:openai',              color: '#ffffff' },
  'LangChain':      { icon: 'simple-icons:langchain',           color: '#84B4A0' },
  'LangGraph':      { icon: 'simple-icons:langchain',           color: '#4A90D9' },
  'PGVector':       { icon: 'simple-icons:postgresql',          color: '#336791' },
  'Timescale':      { icon: 'simple-icons:timescale',           color: '#FDB515' },
  'PostgreSQL':     { icon: 'simple-icons:postgresql',          color: '#4169E1' },
  'SQL Server':     { icon: 'simple-icons:microsoftsqlserver',  color: '#CC2927' },
  'Docker':         { icon: 'simple-icons:docker',              color: '#2496ED' },
  'Google Cloud Platform': { icon: 'simple-icons:googlecloud', color: '#4285F4' },
  'Terraform':      { icon: 'simple-icons:terraform',           color: '#844FBA' },
  'Tekton':         { icon: 'simple-icons:tekton',              color: '#FD495C' },
  'GitHub Actions': { icon: 'simple-icons:githubactions',       color: '#2088FF' },
  'Azure Portal':   { icon: 'simple-icons:microsoftazure',      color: '#0078D4' },
  'Azure Entra ID': { icon: 'simple-icons:microsoftazure',      color: '#0078D4' },
  'Apigee':         { icon: 'simple-icons:googlecloud',         color: '#FBBC04' },
  'Cloudflare':     { icon: 'simple-icons:cloudflare',          color: '#F48120' },
  'SonarQube':      { icon: 'simple-icons:sonarqube',           color: '#4E9BCD' },
  'Git':            { icon: 'simple-icons:git',                 color: '#F05032' },
  'GitHub':         { icon: 'simple-icons:github',              color: '#e0d7ce' },
  'Linux':          { icon: 'simple-icons:linux',               color: '#FCC624' },
  'VS Code':        { icon: 'simple-icons:visualstudiocode',    color: '#007ACC' },
  'Notion':         { icon: 'simple-icons:notion',              color: '#ffffff' },
  'Obsidian':       { icon: 'simple-icons:obsidian',            color: '#7C3AED' },
  'HuggingFace':    { icon: 'simple-icons:huggingface',         color: '#FFD21E' },
};

const byCategory = (cats: string[]) =>
  allSkills.filter(s => cats.includes(s.data.category));

const rows = [
  { skills: byCategory(['design', 'frontend']),       dir: 'left',  speed: 55 },
  { skills: byCategory(['backend', 'ai']),            dir: 'right', speed: 45 },
  { skills: byCategory(['devops']),                   dir: 'left',  speed: 65 },
  { skills: byCategory(['database', 'tools']),        dir: 'right', speed: 50 },
];
---

<section id="skills" class="skills section" data-theme="dark" data-scroll-section data-reveal-section>
  <div class="skills__header container" data-reveal-item>
    <p class="badge">Tecnologias</p>
    <h2 class="skills__title heading-underline">Stack & Ferramentas</h2>
    <p class="skills__subtitle">
      Tecnologias que uso no dia a dia para construir produtos escaláveis e performáticos.
    </p>
  </div>

  <div class="skills__filter container" data-reveal-item>
    <button class="skills__filter-btn active" data-filter="all">Todos</button>
    <button class="skills__filter-btn" data-filter="design">Design</button>
    <button class="skills__filter-btn" data-filter="frontend">Frontend</button>
    <button class="skills__filter-btn" data-filter="backend">Backend</button>
    <button class="skills__filter-btn" data-filter="ai">AI</button>
    <button class="skills__filter-btn" data-filter="devops">DevOps</button>
    <button class="skills__filter-btn" data-filter="database">Database</button>
    <button class="skills__filter-btn" data-filter="tools">Ferramentas</button>
  </div>

  <!-- Ticker (shown when filter = all) — 6 copies so no gaps on wide screens -->
  <div class="skills__ticker-wrap" data-reveal-item id="skills-ticker">
    {rows.map(({ skills: rowSkills, dir, speed }) => (
      rowSkills.length > 0 && (
        <div class="skills__row" style={`--speed: ${speed}s`}>
          <div class={`skills__track skills__track--${dir}`} aria-hidden="true">
            {/* 6 identical copies → animate -16.667% per cycle, seamless on any screen */}
            {[...rowSkills,...rowSkills,...rowSkills,...rowSkills,...rowSkills,...rowSkills].map(skill => {
              const ic = ICON_MAP[skill.data.name];
              return (
                <div class="skill-chip" style={ic ? `--chip-color: ${ic.color}` : '--chip-color: #C0783F'}>
                  <span class="skill-chip__icon">
                    {ic ? <Icon name={ic.icon} /> : <span class="skill-chip__dot" />}
                  </span>
                  <span class="skill-chip__name">{skill.data.name}</span>
                </div>
              );
            })}
          </div>
        </div>
      )
    ))}
  </div>

  <!-- Grid (SSR cards with icons, shown when filter ≠ all) -->
  <div class="skills__grid container" id="skills-grid" aria-hidden="true">
    {allSkills.map(skill => {
      const ic = ICON_MAP[skill.data.name];
      return (
        <div
          class="skill-card"
          data-category={skill.data.category}
          style={ic ? `--chip-color: ${ic.color}` : '--chip-color: #C0783F'}
        >
          <span class="skill-card__icon">
            {ic ? <Icon name={ic.icon} /> : <span class="skill-card__dot" />}
          </span>
          <span class="skill-card__name">{skill.data.name}</span>
        </div>
      );
    })}
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.skills__filter-btn');
  const ticker = document.getElementById('skills-ticker') as HTMLElement;
  const grid   = document.getElementById('skills-grid')  as HTMLElement;
  const cards  = Array.from(grid.querySelectorAll<HTMLElement>('.skill-card'));

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter ?? 'all';

      if (filter === 'all') {
        ticker.style.display = '';
        grid.style.display = 'none';
        grid.setAttribute('aria-hidden', 'true');
      } else {
        ticker.style.display = 'none';
        grid.style.display = 'flex';
        grid.removeAttribute('aria-hidden');

        let visIdx = 0;
        cards.forEach(card => {
          const match = card.dataset.category === filter;
          card.style.display = match ? '' : 'none';
          if (match) {
            // Re-trigger staggered pop animation
            card.style.animation = 'none';
            card.style.animationDelay = '';
            // Force reflow then restore
            void card.offsetWidth;
            card.style.animation = '';
            card.style.animationDelay = (visIdx * 35) + 'ms';
            visIdx++;
          }
        });
      }
    });
  });
</script>

<style lang="scss">
  @use '@/styles/tokens' as *;

  .skills {
    background: var(--bg-primary);
    overflow: hidden;

    &__header {
      text-align: center;
      max-width: 560px;
      margin: 0 auto 3rem;

      .badge { margin-bottom: 1rem; }
    }

    &__title {
      font-family: $font-display;
      font-weight: 600;
      font-size: clamp(2rem, 4vw, 3rem);
      color: $cream;
      margin-bottom: 1.25rem;

      &::after { margin: 1rem auto 0; }
    }

    &__subtitle {
      font-family: $font-body;
      font-size: 1rem;
      color: rgba($oat, 0.7);
      line-height: 1.7;
    }

    &__filter {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      margin-bottom: 2.5rem;
    }

    &__filter-btn {
      padding: 0.5rem 1.25rem;
      border: 1px solid rgba($oat, 0.15);
      border-radius: 2rem;
      background: transparent;
      color: rgba($oat, 0.55);
      font-family: $font-body;
      font-size: 0.8125rem;
      cursor: pointer;
      transition: all 0.2s;

      &:hover {
        border-color: rgba($caramel, 0.4);
        color: $oat;
      }

      &.active {
        background: rgba($caramel, 0.12);
        border-color: $caramel;
        color: $oat;
      }
    }

    &__ticker-wrap {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      padding: 0.5rem 0 1rem;
      mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 8%,
        black 92%,
        transparent 100%
      );
    }

    &__row {
      overflow: hidden;
      &:hover .skills__track { animation-play-state: paused; }
    }

    &__track {
      display: flex;
      gap: 0.75rem;
      width: max-content;

      &--left  { animation: ticker-left  var(--speed, 55s) linear infinite; }
      &--right { animation: ticker-right var(--speed, 55s) linear infinite; }
    }

    &__grid {
      display: none;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
      padding: 1rem 1rem 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }
  }

  /* ── Ticker chip ── */
  .skill-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem 0.5rem 0.75rem;
    background: rgba($oat, 0.04);
    border: 1px solid rgba($oat, 0.1);
    border-radius: 2rem;
    white-space: nowrap;
    transition: background 0.2s, border-color 0.2s;
    cursor: default;

    &:hover {
      background: rgba($oat, 0.08);
      border-color: rgba($oat, 0.2);
    }

    &__icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 1.125rem;
      height: 1.125rem;
      color: var(--chip-color, #C0783F);
      flex-shrink: 0;
      svg { width: 100%; height: 100%; }
    }

    &__dot {
      display: block;
      width: 0.5rem; height: 0.5rem;
      border-radius: 50%;
      background: var(--chip-color, #C0783F);
      margin: auto;
    }

    &__name {
      font-family: $font-body;
      font-size: 0.8125rem;
      font-weight: 400;
      color: rgba($oat, 0.85);
      letter-spacing: 0.01em;
    }
  }

  /* ── Filter grid card ── */
  .skill-card {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1.125rem 0.625rem 0.875rem;
    border: 1px solid rgba($oat, 0.1);
    border-radius: 0.625rem;
    background: rgba($oat, 0.04);
    cursor: default;
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
    animation: card-pop 0.22s ease-out both;

    &:hover {
      background: rgba($oat, 0.09);
      border-color: var(--chip-color, #C0783F);
      transform: translateY(-2px);
    }

    &__icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 1.25rem;
      height: 1.25rem;
      color: var(--chip-color, #C0783F);
      flex-shrink: 0;
      svg { width: 100%; height: 100%; }
    }

    &__dot {
      display: block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--chip-color, #C0783F);
      flex-shrink: 0;
    }

    &__name {
      font-family: $font-body;
      font-size: 0.875rem;
      color: rgba($oat, 0.88);
      white-space: nowrap;
    }
  }

  /* 6 copies → one cycle = 1/6 of total = 16.667% */
  @keyframes ticker-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-16.6667%); }
  }

  @keyframes ticker-right {
    from { transform: translateX(-16.6667%); }
    to   { transform: translateX(0); }
  }

  @keyframes card-pop {
    from { opacity: 0; transform: scale(0.85) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>
