---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recent = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="blog" class="blog section" data-theme="light" data-scroll-section>
  <div class="container">
    <header class="blog__header" data-scroll-reveal>
      <p class="badge">Blog</p>
      <h2 class="blog__title heading-underline">Escritos Recentes</h2>
      <p class="blog__subtitle">
        Reflexões sobre desenvolvimento, arquitetura e o ofício de construir para a web.
      </p>
    </header>

    <div class="blog__grid">
      {recent.map((post, i) => (
        <article class={`blog-card ${i === 0 ? 'blog-card--featured' : ''}`} data-scroll-reveal>
          <div class="blog-card__image">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
            ) : (
              <div class="blog-card__placeholder" aria-hidden="true">
                <span>{post.data.title.charAt(0)}</span>
              </div>
            )}
          </div>

          <div class="blog-card__content">
            <div class="blog-card__meta">
              <span class="badge">{post.data.category}</span>
              {post.data.readingTime && (
                <span class="blog-card__reading-time">{post.data.readingTime} min</span>
              )}
            </div>

            <h3 class="blog-card__title">
              <a href={`/blog/${post.slug}`} class="underline-accent">
                {post.data.title}
              </a>
            </h3>

            <p class="blog-card__description">{post.data.description}</p>

            <div class="blog-card__footer">
              <time
                class="blog-card__date"
                datetime={post.data.pubDate.toISOString()}
              >
                {post.data.pubDate.toLocaleDateString('pt-BR', {
                  year: 'numeric', month: 'short', day: 'numeric'
                })}
              </time>
              <a href={`/blog/${post.slug}`} class="btn btn-ghost">
                Ler →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="blog__cta" data-scroll-reveal>
      <a href="/blog" class="btn btn-outline">Ver Todos os Posts →</a>
    </div>
  </div>
</section>

<style lang="scss">
  @use '@/styles/tokens' as *;

  .blog {
    background: var(--bg-primary);

    &__header {
      text-align: center;
      max-width: 540px;
      margin: 0 auto 4rem;

      .badge { margin-bottom: 1rem; }
    }

    &__title {
      font-family: $font-display;
      font-weight: 600;
      font-size: clamp(2rem, 4vw, 3rem);
      color: $ink;
      margin-bottom: 1.25rem;

      &::after { margin: 1rem auto 0; }
    }

    &__subtitle {
      font-family: $font-body;
      font-size: 1rem;
      color: $charcoal;
      line-height: 1.7;
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 3rem;

      @include respond-to(md) { grid-template-columns: repeat(3, 1fr); }
    }

    &__cta {
      text-align: center;
    }
  }

  .blog-card {
    background: $fog;
    border-radius: 4px;
    overflow: hidden;
    @include border-warm(0.15);
    @include shadow-sm;
    transition: transform $transition-slow, box-shadow $transition-base;

    &:hover {
      transform: translateY(-4px);
      @include shadow-md;
    }

    &__image {
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: $oat;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform $transition-slow;
      }
    }

    &:hover &__image img { transform: scale(1.04); }

    &__placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, $oat 0%, $cream 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: $font-display;
      font-size: 3rem;
      font-style: italic;
      color: $caramel;
    }

    &__content {
      padding: 1.5rem;
    }

    &__meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    &__reading-time {
      font-family: $font-code;
      font-size: 0.6875rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: $muted;
    }

    &__title {
      font-family: $font-display;
      font-weight: 600;
      font-size: 1.25rem;
      line-height: 1.3;
      color: $ink;
      margin-bottom: 0.75rem;

      a { color: inherit; }
    }

    &__description {
      font-family: $font-body;
      font-size: 0.875rem;
      color: $charcoal;
      line-height: 1.7;
      margin-bottom: 1.25rem;
    }

    &__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    &__date {
      font-family: $font-code;
      font-size: 0.6875rem;
      letter-spacing: 0.04em;
      color: $muted;
    }
  }
</style>
