---
import { Icon } from 'astro-icon/components';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const techCategories = [
  {
    label: 'Design',
    symbol: '✦',
    items: [
      { name: 'Figma',      icon: 'simple-icons:figma',             color: '#F24E1E' },
      { name: 'Photoshop',  icon: 'simple-icons:adobephotoshop',    color: '#31A8FF' },
    ],
  },
  {
    label: 'Frontend',
    symbol: '◈',
    items: [
      { name: 'React',      icon: 'simple-icons:react',       color: '#61DAFB' },
      { name: 'TypeScript', icon: 'simple-icons:typescript',  color: '#3178C6' },
      { name: 'Next.js',    icon: 'simple-icons:nextdotjs',   color: '#ffffff' },
      { name: 'Three.js',   icon: 'simple-icons:threedotjs',  color: '#ffffff' },
      { name: 'GSAP',       icon: 'simple-icons:greensock',   color: '#88CE02' },
      { name: 'Leaflet',    icon: 'simple-icons:leaflet',     color: '#199900' },
    ],
  },
  {
    label: 'Backend',
    symbol: '⬡',
    items: [
      { name: 'Node.js',  icon: 'simple-icons:nodedotjs', color: '#5FA04E' },
      { name: 'Python',   icon: 'simple-icons:python',    color: '#3776AB' },
      { name: 'NestJS',   icon: 'simple-icons:nestjs',    color: '#E0234E' },
      { name: 'Prisma',   icon: 'simple-icons:prisma',    color: '#2D3748' },
      { name: 'TypeORM',  icon: 'simple-icons:typeorm',   color: '#FE0803' },
    ],
  },
  {
    label: 'AI',
    symbol: '◉',
    items: [
      { name: 'Claude',     icon: 'simple-icons:anthropic', color: '#D4A27F' },
      { name: 'OpenAI',     icon: 'simple-icons:openai',    color: '#ffffff' },
      { name: 'LangChain',  icon: 'simple-icons:langchain', color: '#1C3C3C' },
      { name: 'LangGraph',  icon: 'simple-icons:langchain', color: '#4A90D9' },
      { name: 'PGVector',   icon: 'simple-icons:postgresql',color: '#336791' },
      { name: 'Timescale',  icon: 'simple-icons:timescale', color: '#FDB515' },
    ],
  },
  {
    label: 'Infra',
    symbol: '◌',
    items: [
      { name: 'Docker',      icon: 'simple-icons:docker',          color: '#2496ED' },
      { name: 'GCP',         icon: 'simple-icons:googlecloud',     color: '#4285F4' },
      { name: 'Terraform',   icon: 'simple-icons:terraform',       color: '#844FBA' },
      { name: 'Tekton',      icon: 'simple-icons:tekton',          color: '#FD495C' },
      { name: 'Apigee',      icon: 'simple-icons:googlecloud',     color: '#FBBC04' },
      { name: 'SonarQube',   icon: 'simple-icons:sonarqube',       color: '#4E9BCD' },
      { name: 'Azure',       icon: 'simple-icons:microsoftazure',  color: '#0078D4' },
    ],
  },
];

const aiStack = [
  { name: 'Claude API',    icon: 'simple-icons:anthropic',   color: '#D4A27F', desc: 'Anthropic Claude 3.5/4'       },
  { name: 'Claude Code',   icon: 'simple-icons:anthropic',   color: '#C8956C', desc: 'AI-powered CLI dev tool'      },
  { name: 'OpenAI',        icon: 'simple-icons:openai',      color: '#ffffff', desc: 'GPT-4o, Assistants API'       },
  { name: 'LangChain',     icon: 'simple-icons:langchain',   color: '#1C3C3C', desc: 'Chains & Agents'              },
  { name: 'LangGraph',     icon: 'simple-icons:langchain',   color: '#4A90D9', desc: 'Multi-Agent Graphs'           },
  { name: 'Hugging Face',  icon: 'simple-icons:huggingface', color: '#FFD21E', desc: 'Transformers & Models'        },
  { name: 'PGVector',      icon: 'simple-icons:postgresql',  color: '#336791', desc: 'Vector Search & Embeddings'   },
  { name: 'Timescale',     icon: 'simple-icons:timescale',   color: '#FDB515', desc: 'Time-series & RAG storage'    },
];

const aiSkills = [
  'Prompt Engineering',
  'Agent Architecture',
  'RAG Pipelines',
  'Tool Use / Function Calling',
  'Multi-Agent Systems',
  'Fine-tuning',
  'Embeddings & Vector Search',
  'Claude Agent SDK',
];

---

<!--  HERO SCROLL WRAPPER  -->
<div class="hero-scroll" data-hero-scroll data-hero>

  <!-- Pinned viewport (100vh, stays in place while user scrolls through the wrapper) -->
  <!-- style injects CSS var so the background-image path is correct regardless of base URL -->
  <div
    class="hero-scroll__viewport"
    style={`--frame0-url: url('${base}assets/frames/scroll-animation-1/ezgif-frame-001.jpg')`}
  >

    <!--  Frame canvas background  -->
    <canvas
      class="hero-canvas"
      data-hero-canvas
      data-frame-base={`${base}assets/frames/scroll-animation-1/`}
      data-frame-count="240"
      aria-hidden="true"
    ></canvas>
    <!-- Dark gradient overlay for text legibility -->
    <div class="hero-overlay" aria-hidden="true"></div>
    <!-- Watermark cover: hides generator branding at bottom corners -->
    <div class="hero-wm-cover hero-wm-cover--bl" aria-hidden="true"></div>
    <div class="hero-wm-cover hero-wm-cover--br" aria-hidden="true"></div>

    <!-- """""""""""""""""""""""" SCENE 0  Intro """""""""""""""""""""""" -->
    <section class="hero-scene hero-scene--0 active" aria-label="Introdução">
      <div class="hero-scene__inner container">

        <!-- LEFT -->
        <div class="hero__left" data-parallax="-0.6">
          <p class="hero__meta">Dev FullStack + DevOps</p>

          <h1 class="hero__title">
            <span class="hero__title-first">Benjamin</span>
            <span class="hero__title-last">Suzarte</span>
          </h1>

          <p class="hero__subtitle">
            Do design ao deploy, entrego soluções completas priorizando o cliente — com IA integrada, foco em resultado e compromisso com prazos.
          </p>

          <div class="hero__social">
            <a href="https://github.com/devsuzarte" class="hero__social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
              <span>devsuzarte</span>
            </a>
            <a href="https://linkedin.com/in/benjamin-suzarte" class="hero__social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <span>Juan Benjamin</span>
            </a>
          </div>

          <div class="hero__actions">
            <a href="/#projects" class="btn btn-primary">
              Ver Projetos
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="mailto:devsuzarte@gmail.com" class="btn btn-ghost">devsuzarte@gmail.com</a>
          </div>
        </div>

        <!-- RIGHT: terminal -->
        <div class="hero__right" aria-hidden="true" data-parallax="1.2">
          <div class="hero__terminal">
            <div class="hero__terminal-header">
              <span class="hero__terminal-dot" style="background:#ff5f57"></span>
              <span class="hero__terminal-dot" style="background:#febc2e"></span>
              <span class="hero__terminal-dot" style="background:#28c840"></span>
              <span class="hero__terminal-title">devsuzarte.ts</span>
            </div>
            <pre class="hero__terminal-body"><code><span class="t-kw">const</span> <span class="t-var">dev</span> <span class="t-op">=</span> <span class="t-punct">&#123;</span>
  <span class="t-key">name</span><span class="t-punct">:</span>   <span class="t-str">'Juan Benjamin Almeida Suzarte'</span><span class="t-punct">,</span>
  <span class="t-key">alias</span><span class="t-punct">:</span>  <span class="t-str">'devsuzarte'</span><span class="t-punct">,</span>
  <span class="t-key">role</span><span class="t-punct">:</span>   <span class="t-str">'Fullstack Developer'</span><span class="t-punct">,</span>
  <span class="t-key">english</span><span class="t-punct">:</span> <span class="t-kw">true</span><span class="t-punct">,</span>
  <span class="t-key">stack</span><span class="t-punct">:</span>  <span class="t-punct">[</span>
    <span class="t-str">'React'</span><span class="t-punct">,</span> <span class="t-str">'NestJS'</span><span class="t-punct">,</span>
    <span class="t-str">'Google Cloud'</span><span class="t-punct">,</span> <span class="t-str">'LangChain'</span><span class="t-punct">,</span>
  <span class="t-punct">]</span><span class="t-punct">,</span>
  <span class="t-key">status</span><span class="t-punct">:</span> <span class="t-str">'disponível'</span> <span class="t-comment">// ✓</span>
<span class="t-punct">&#125;</span></code></pre>
          </div>

          <div class="hero__scroll-hint" aria-hidden="true">
            <span>scroll para explorar</span>
            <svg width="12" height="20" viewBox="0 0 12 20" fill="none">
              <rect x="1" y="1" width="10" height="18" rx="5" stroke="rgba(245,237,224,0.3)" stroke-width="1.5"/>
              <circle class="scroll-dot" cx="6" cy="5" r="2" fill="rgba(192,120,64,0.8)"/>
            </svg>
          </div>
        </div>

      </div>
    </section>

    <!-- """""""""""""""""""""""" SCENE 1  Tech Stack """""""""""""""""""""""" -->
    <section class="hero-scene hero-scene--1" aria-label="Stack tecnológica">
      <!-- SVG connection web between tech nodes (populated by JS) -->
      <svg class="tech-web" data-tech-web aria-hidden="true"></svg>
      <!-- Header: top-left -->
      <div class="s1-header" data-s1-header data-parallax="-0.4">
        <p class="scene-label">Stack</p>
        <h2 class="scene-title">Tecnologias<br /><em>que domino</em></h2>
        <p class="s1-sub">Frontend · Backend · Data · DevOps · AI</p>
      </div>

      <!-- Tech categories: 5 columns, scattered right side -->
      <div class="tech-categories" data-tech-grid data-parallax="0.35">
        {techCategories.map((cat, ci) => (
          <div class="tech-cat" style={`--ci:${ci}`} data-tech-cat>
            <div class="tech-cat__head">
              <span class="tech-cat__sym" aria-hidden="true">{cat.symbol}</span>
              <p class="tech-cat__label">{cat.label}</p>
            </div>
            <div class="tech-cat__items">
              {cat.items.map((tech) => (
                <div class="tech-item" style={`--color:${tech.color}`} data-tech-item>
                  <div class="tech-item__icon">
                    <Icon name={tech.icon} width={20} height={20} />
                  </div>
                  <span class="tech-item__name">{tech.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Decorative large label -->
      <span class="s1-bg-word" aria-hidden="true" data-parallax="-0.2">STACK</span>
    </section>

    <!-- """""""""""""""""""""""" SCENE 2  Ofereço para sua empresa """""""""""""""""""""""" -->
    <section class="hero-scene hero-scene--2" aria-label="O que ofereço à sua empresa">

      <!-- Header: top-left -->
      <div class="s2-header" data-s2-header data-parallax="-0.35">
        <p class="scene-label">Para sua empresa</p>
        <h2 class="scene-title">Ofereço para<br /><em>sua empresa</em></h2>
      </div>

      <!-- Card 1: Automação  upper-left -->
      <div class="biz-card biz-card--1" data-biz-card data-parallax="0.5">
        <svg class="biz-card__svg" viewBox="0 0 180 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="22" width="36" height="20" rx="5" fill="rgba(192,120,64,0.08)" stroke="rgba(192,120,64,0.45)" stroke-width="1.5"/>
          <text x="20" y="35" text-anchor="middle" font-size="7" fill="rgba(192,120,64,0.7)" font-family="monospace">INPUT</text>
          <line x1="38" y1="32" x2="64" y2="32" stroke="rgba(192,120,64,0.35)" stroke-width="1.2" stroke-dasharray="4,3"/>
          <polygon points="61,29 65,32 61,35" fill="rgba(192,120,64,0.5)"/>
          <rect x="66" y="14" width="48" height="36" rx="5" fill="rgba(192,120,64,0.12)" stroke="rgba(192,120,64,0.55)" stroke-width="1.5"/>
          <text x="90" y="29" text-anchor="middle" font-size="7" fill="rgba(245,237,224,0.7)" font-family="monospace">PROCESS</text>
          <text x="90" y="41" text-anchor="middle" font-size="8" fill="rgba(192,120,64,0.9)" font-family="monospace">AUTO</text>
          <line x1="114" y1="32" x2="140" y2="32" stroke="rgba(192,120,64,0.35)" stroke-width="1.2" stroke-dasharray="4,3"/>
          <polygon points="137,29 141,32 137,35" fill="rgba(192,120,64,0.5)"/>
          <rect x="142" y="6" width="36" height="52" rx="5" fill="rgba(192,120,64,0.2)" stroke="#c07840" stroke-width="2"/>
          <text x="160" y="30" text-anchor="middle" font-size="7" fill="rgba(245,237,224,0.9)" font-family="monospace">OUTPUT</text>
          <text x="160" y="44" text-anchor="middle" font-size="14" fill="#d4a878" font-family="monospace">✓</text>
</text>
        </svg>
        <p class="biz-card__metric">– 65%</p>
        <p class="biz-card__title">Tempo Operacional</p>
        <p class="biz-card__desc">Automação de fluxos repetitivos de ponta a ponta</p>
      </div>

      <!-- Card 2: API Integration  upper-right -->
      <div class="biz-card biz-card--2" data-biz-card data-parallax="-0.4">
        <svg class="biz-card__svg" viewBox="0 0 160 80" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="80" cy="40" r="18" fill="rgba(192,120,64,0.15)" stroke="#c07840" stroke-width="2"/>
          <text x="80" y="44" text-anchor="middle" font-size="9" fill="#c07840" font-family="monospace">API</text>
          <circle cx="22" cy="18" r="9" fill="rgba(192,120,64,0.08)" stroke="rgba(192,120,64,0.5)" stroke-width="1.5"/>
          <circle cx="138" cy="18" r="9" fill="rgba(192,120,64,0.08)" stroke="rgba(192,120,64,0.5)" stroke-width="1.5"/>
          <circle cx="22" cy="62" r="9" fill="rgba(192,120,64,0.08)" stroke="rgba(192,120,64,0.5)" stroke-width="1.5"/>
          <circle cx="138" cy="62" r="9" fill="rgba(192,120,64,0.08)" stroke="rgba(192,120,64,0.5)" stroke-width="1.5"/>
          <circle cx="80" cy="8" r="6" fill="rgba(192,120,64,0.1)" stroke="rgba(192,120,64,0.4)" stroke-width="1.5"/>
          <circle cx="80" cy="72" r="6" fill="rgba(192,120,64,0.1)" stroke="rgba(192,120,64,0.4)" stroke-width="1.5"/>
          <line x1="31" y1="22" x2="63" y2="35" stroke="rgba(192,120,64,0.3)" stroke-width="1" stroke-dasharray="3,2"/>
          <line x1="129" y1="22" x2="97" y2="35" stroke="rgba(192,120,64,0.3)" stroke-width="1" stroke-dasharray="3,2"/>
          <line x1="31" y1="58" x2="63" y2="45" stroke="rgba(192,120,64,0.3)" stroke-width="1" stroke-dasharray="3,2"/>
          <line x1="129" y1="58" x2="97" y2="45" stroke="rgba(192,120,64,0.3)" stroke-width="1" stroke-dasharray="3,2"/>
          <line x1="80" y1="14" x2="80" y2="22" stroke="rgba(192,120,64,0.3)" stroke-width="1" stroke-dasharray="3,2"/>
          <line x1="80" y1="58" x2="80" y2="66" stroke="rgba(192,120,64,0.3)" stroke-width="1" stroke-dasharray="3,2"/>
        </svg>
        <p class="biz-card__metric">+40%</p>
        <p class="biz-card__title">Eficiência de Sistemas</p>
        <p class="biz-card__desc">Integrações de API, webhooks e sincronização de dados</p>
      </div>

      <!-- Card 3: Deploy speed  lower-center-left -->
      <div class="biz-card biz-card--3" data-biz-card data-parallax="0.6">
        <svg class="biz-card__svg" viewBox="0 0 180 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <linearGradient id="tg" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="rgba(192,120,64,0.18)"/>
              <stop offset="100%" stop-color="rgba(192,120,64,0)"/>
            </linearGradient>
          </defs>
          <polygon points="10,52 40,44 70,40 100,30 130,18 155,8 168,4 168,54 10,54" fill="url(#tg)"/>
          <polyline points="10,52 40,44 70,40 100,30 130,18 155,8 168,4" stroke="#c07840" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="100" cy="30" r="3.5" fill="rgba(192,120,64,0.6)" stroke="#c07840" stroke-width="1"/>
          <circle cx="168" cy="4" r="5" fill="#d4a878"/>
          <line x1="8" y1="54" x2="174" y2="54" stroke="rgba(192,120,64,0.2)" stroke-width="1"/>
          <text x="8" y="59" font-size="6" fill="rgba(192,120,64,0.4)" font-family="monospace">JAN</text>
          <text x="160" y="59" font-size="6" fill="rgba(192,120,64,0.7)" font-family="monospace">NOW</text>
        </svg>
        <p class="biz-card__metric">3× faster</p>
        <p class="biz-card__title">Deploy Contínuo</p>
        <p class="biz-card__desc">CI/CD, zero downtime, rollback automático</p>
      </div>

      <!-- Decorative large label -->
      <span class="s2-bg-word" aria-hidden="true" data-parallax="-0.15">VANTAGENS</span>

      <!-- Card 4: Monitoring  lower-right -->
      <div class="biz-card biz-card--4" data-biz-card data-parallax="-0.3">
        <svg class="biz-card__svg" viewBox="0 0 140 72" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M 14 58 A 56 56 0 0 1 126 58" stroke="rgba(192,120,64,0.15)" stroke-width="10" stroke-linecap="round"/>
          <path d="M 14 58 A 56 56 0 0 1 99 21" stroke="#c07840" stroke-width="10" stroke-linecap="round"/>
          <line x1="70" y1="58" x2="96" y2="26" stroke="#d4a878" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="70" cy="58" r="6" fill="#c07840"/>
          <circle cx="70" cy="58" r="3" fill="#d4a878"/>
          <text x="12" y="70" font-size="7" fill="rgba(192,120,64,0.4)" font-family="monospace">0%</text>
          <text x="118" y="70" font-size="7" fill="rgba(192,120,64,0.4)" font-family="monospace">100%</text>
          <text x="70" y="46" text-anchor="middle" font-size="8" fill="rgba(245,237,224,0.5)" font-family="monospace">KPI</text>
          <!-- small bars on the side -->
          <rect x="2" y="28" width="6" height="28" rx="2" fill="rgba(192,120,64,0.15)"/>
          <rect x="132" y="36" width="6" height="20" rx="2" fill="rgba(192,120,64,0.15)"/>
        </svg>
        <p class="biz-card__metric">360°</p>
        <p class="biz-card__title">Visibilidade Total</p>
        <p class="biz-card__desc">Dashboards, alertas e monitoramento em tempo real</p>
      </div>

    </section>

    <!-- """""""""""""""""""""""" SCENE 3  AI Experience """""""""""""""""""""""" -->
    <section class="hero-scene hero-scene--3" aria-label="Experiência com IA">

      <!-- Header: top-center -->
      <div class="s3-header" data-s3-header data-parallax="-0.3">
        <p class="scene-label">IA & Automação</p>
        <h2 class="scene-title">Experiência com<br /><em>inteligência artificial</em></h2>
      </div>

      <!-- AI tools: left column -->
      <div class="ai-tools" data-ai-tools data-parallax="0.45">
        {aiStack.map((ai, i) => (
          <div class="ai-tool" style={`--i:${i}; --color:${ai.color}`} data-ai-item>
            <div class="ai-tool__icon">
              <Icon name={ai.icon} width={24} height={24} />
            </div>
            <div class="ai-tool__text">
              <span class="ai-tool__name">{ai.name}</span>
              <span class="ai-tool__desc">{ai.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Skills: right column, offset down -->
      <div class="ai-skills" data-ai-skills data-parallax="-0.4">
        <p class="ai-skills__heading">Competências</p>
        <ul class="ai-skills__list" role="list">
          {aiSkills.map((skill, i) => (
            <li class="ai-skills__item" style={`--i:${i}`} data-ai-skill>
              <span class="ai-skills__dot" aria-hidden="true"></span>
              {skill}
            </li>
          ))}
