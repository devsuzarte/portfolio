---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const rest = allProjects
  .filter(p => !p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<section id="projects" class="projects section" data-theme="light" data-scroll-section data-reveal-section>
  <!-- Floating geometric shapes -->
  <div class="projects__shape projects__shape--1" aria-hidden="true"></div>
  <div class="projects__shape projects__shape--2" aria-hidden="true"></div>
  <div class="projects__shape projects__shape--3" aria-hidden="true"></div>
  <div class="projects__shape projects__shape--4" aria-hidden="true"></div>
  <div class="container">
    <header class="projects__header" data-scroll-reveal data-reveal-item>
      <p class="badge">Portfólio</p>
      <h2 class="projects__title heading-underline">Projetos Selecionados</h2>
      <p class="projects__subtitle">
        Uma seleção de trabalhos que demonstram meu domínio técnico e atenção ao detalhe.
      </p>
    </header>

    <!-- Featured projects -->
    <div class="projects__featured" data-reveal-item>
      {featured.map((project, i) => (
        <article
          class={`project-feature ${i % 2 === 1 ? 'project-feature--reverse' : ''}`}
          data-scroll-reveal
        >
          <div class="project-feature__visual">
            <div class="project-feature__image-wrap">
              {project.data.thumbnail ? (
                <img
                  src={project.data.thumbnail}
                  alt={project.data.title}
                  loading="lazy"
                />
              ) : (
                <div class="project-feature__placeholder">
                  <span>{project.data.title.charAt(0)}</span>
                </div>
              )}
            </div>
          </div>

          <div class="project-feature__content">
            <p class="project-feature__meta badge">{project.data.category}</p>
            <h3 class="project-feature__title">{project.data.title}</h3>
            <p class="project-feature__description">{project.data.description}</p>

            <div class="project-feature__tech">
              {project.data.tech.slice(0, 5).map(t => (
                <span class="badge">{t}</span>
              ))}
            </div>

            <div class="project-feature__actions">
              {(project.data.demo || project.data.github) && (
                <a
                  href={project.data.demo || project.data.github}
                  class="btn btn-primary"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Ver Projeto →
                </a>
              )}
              {project.data.demo && project.data.github && (
                <a
                  href={project.data.github}
                  class="btn btn-outline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  GitHub
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Other projects grid -->
    {rest.length > 0 && (
      <div class="projects__grid" data-reveal-item>
        {rest.map(project => (
          <article class="card card--light project-card" data-scroll-reveal>
            <div class="card__image">
              {project.data.thumbnail ? (
                <img src={project.data.thumbnail} alt={project.data.title} loading="lazy" />
              ) : (
                <div class="project-card__placeholder">
                  <span>{project.data.title.charAt(0)}</span>
                </div>
              )}
            </div>
            <div class="card__content">
              <h3 class="card__title">{project.data.title}</h3>
              <p class="card__description">{project.data.description}</p>
              <div class="card__tags">
                {project.data.tags.slice(0, 3).map(tag => (
                  <span class="badge">{tag}</span>
                ))}
              </div>
              {(project.data.demo || project.data.github) && (
                <a
                  href={project.data.demo || project.data.github}
                  class="btn btn-ghost"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Ver Projeto →
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    )}

  </div>
</section>

<style lang="scss">
  @use '@/styles/tokens' as *;

  .projects {
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;

    &__shape {
      position: absolute;
      pointer-events: none;
      opacity: 0.12;
    }

    &__shape--1 {
      width: 120px; height: 120px;
      border: 1.5px solid $caramel;
      border-radius: 50%;
      top: 8%; left: 3%;
      animation: shape-float 12s ease-in-out infinite alternate;
    }

    &__shape--2 {
      width: 60px; height: 60px;
      background: rgba($sienna, 0.3);
      border-radius: 4px;
      top: 20%; right: 6%;
      animation: shape-spin 20s linear infinite;
    }

    &__shape--3 {
      width: 80px; height: 80px;
      border: 1px solid $sienna;
      border-radius: 50%;
      bottom: 15%; left: 8%;
      animation: shape-float 16s ease-in-out infinite alternate-reverse;
    }

    &__shape--4 {
      width: 40px; height: 40px;
      background: rgba($caramel, 0.25);
      border-radius: 50%;
      bottom: 30%; right: 10%;
      animation: shape-float 9s ease-in-out infinite alternate;
    }

    &__header {
      text-align: center;
      max-width: 560px;
      margin: 0 auto 5rem;

      .badge { margin-bottom: 1rem; }
    }

    &__title {
      font-family: $font-display;
      font-weight: 600;
      font-size: clamp(2rem, 4vw, 3rem);
      color: $ink;
      margin-bottom: 1.25rem;

      &::after { margin: 1rem auto 0; }
    }

    &__subtitle {
      font-family: $font-body;
      font-size: 1rem;
      color: $charcoal;
      line-height: 1.7;
    }

    &__featured {
      display: flex;
      flex-direction: column;
      gap: 6rem;
      margin-bottom: 5rem;
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 3rem;

      @include respond-to(md) { grid-template-columns: repeat(2, 1fr); }
      @include respond-to(lg) { grid-template-columns: repeat(3, 1fr); }
    }

    &__cta {
      text-align: center;
    }
  }

  .project-feature {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;

    @include respond-to(lg) {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }

    &--reverse {
      @include respond-to(lg) {
        direction: rtl;

        > * { direction: ltr; }
      }
    }

    &__visual {}

    &__image-wrap {
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border-radius: 4px;
      @include shadow-md;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform $transition-slow;
      }

      &:hover img { transform: scale(1.04); }
    }

    &__placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, $oat 0%, $cream 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: $font-display;
      font-size: 5rem;
      font-style: italic;
      color: $caramel;
    }

    &__content {}

    &__meta {
      margin-bottom: 1rem;
    }

    &__title {
      font-family: $font-display;
      font-weight: 600;
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      color: $ink;
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    &__description {
      font-family: $font-body;
      font-size: 1rem;
      line-height: 1.75;
      color: $charcoal;
      margin-bottom: 1.5rem;
    }

    &__tech {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2rem;
    }

    &__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }
  }

  @keyframes shape-float {
    from { transform: translate(0, 0) rotate(0deg); }
    to   { transform: translate(15px, -20px) rotate(45deg); }
  }

  @keyframes shape-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .project-card {
    &__placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, $oat 0%, $cream 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: $font-display;
      font-size: 3rem;
      font-style: italic;
      color: $caramel;
    }
  }
</style>
