---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section id="about" class="about section" data-theme="light" data-scroll-section data-reveal-section>
  <div class="about__orb about__orb--1" aria-hidden="true"></div>
  <div class="about__orb about__orb--2" aria-hidden="true"></div>
  <div class="about__orb about__orb--3" aria-hidden="true"></div>
  <div class="container about__inner">
    <div class="about__text" data-reveal-item>
      <p class="about__label badge">Sobre mim</p>
      <h2 class="about__title heading-underlin">
        Do design ao deploy <br>
        <em>IA, Cloud e foco em resultado</em>
      </h2>

      <div class="about__body-block">
        <p class="about__body" data-typewriter="1">Com mais de 4 anos no mercado, sou desenvolvedor Pleno atuando em empresas de grande porte como Ford e em projetos freelance próprios. Atuo também como professor particular de programação, o que me faz buscar sempre clareza técnica e evolução contínua.</p>
        <p class="about__body" data-typewriter="2">Programação é tanto minha profissão quanto meu hobby — me aprofundo especialmente em IA, Cloud e arquiteturas modernas. Tenho inglês intermediário-avançado, o que me permite trabalhar com documentações, equipes e clientes internacionais sem barreiras. Fora do computador, toco violão, canto e curto andar de bicicleta.</p>
      </div>
    </div>

    <div class="about__visual" data-reveal-item>
      <div class="about__photo-perspective">
        <div class="about__photo-frame">
          <div class="about__photo-wrap">
            <img
              src={`${base}assets/images/about/me.jpg`}
              alt="Foto de Benjamin Suzarte"
              class="about__photo"
              loading="lazy"
            />
          </div>
          <div class="about__photo-accent" aria-hidden="true"></div>
        </div>
      </div>
    </div>

    <div class="about__stats" data-scroll-reveal data-reveal-item>
      <div class="about__stat">
        <span class="about__stat-number">4+</span>
        <span class="about__stat-label">Anos de experiência</span>
      </div>
      <div class="about__stat">
        <span class="about__stat-number">8+</span>
        <span class="about__stat-label">Projetos entregues</span>
      </div>
      <div class="about__stat">
        <span class="about__stat-number">100%</span>
        <span class="about__stat-label">Comprometimento</span>
      </div>
      <div class="about__stat">
        <span class="about__stat-number">Inglês</span>
        <span class="about__stat-label">Intermediário / Avançado</span>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const els = Array.from(document.querySelectorAll<HTMLElement>('[data-typewriter]'));
    if (els.length === 0) return;

    // Store trimmed texts and reserve natural height BEFORE clearing
    const texts = els.map(el => {
      const text = (el.textContent ?? '').trim().replace(/\s+/g, ' ');
      const h = el.getBoundingClientRect().height || el.scrollHeight;
      if (h > 0) el.style.minHeight = h + 'px';
      el.textContent = '';
      return text;
    });

    // Cursor is a CSS ::after on .about__body--typing / --done
    const typeEl = (el: HTMLElement, text: string, cb: () => void) => {
      el.classList.add('about__body--typing');
      let i = 0;
      const tick = () => {
        el.textContent += text[i++];
        if (i < text.length) {
          setTimeout(tick, 10);
        } else {
          el.classList.remove('about__body--typing');
          cb();
        }
      };
      setTimeout(tick, 10);
    };

    let started = false;
    const obs = new IntersectionObserver(entries => {
      if (started || !entries[0].isIntersecting) return;
      started = true;
      obs.disconnect();

      const runSeq = (idx: number) => {
        if (idx >= els.length) {
          // All done — keep cursor blinking on last paragraph
          els[els.length - 1].classList.add('about__body--done');
          return;
        }
        typeEl(els[idx], texts[idx], () => runSeq(idx + 1));
      };
      runSeq(0);
    }, { threshold: 0.15 });

    obs.observe(els[0]);
  })();
</script>

<style lang="scss">
  @use '@/styles/tokens' as *;

  .about {
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;

    &__orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
      opacity: 0.35;
    }

    &__orb--1 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba($caramel, 0.5), transparent 70%);
      top: -10%;  left: -8%;
      animation: orb-drift 14s ease-in-out infinite alternate;
    }

    &__orb--2 {
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba($sienna, 0.4), transparent 70%);
      bottom: 5%;  right: 5%;
      animation: orb-drift 18s ease-in-out infinite alternate-reverse;
    }

    &__orb--3 {
      width: 200px; height: 200px;
      background: radial-gradient(circle, rgba($amber, 0.35), transparent 70%);
      top: 50%;  left: 55%;
      animation: orb-drift 11s ease-in-out infinite alternate;
    }

    &__inner {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      align-items: center;

      @include respond-to(lg) {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto auto;
        grid-template-areas:
          "text  visual"
          "stats visual";
        gap: 2.5rem 5rem;
        align-items: start;
      }
    }

    &__text   { @include respond-to(lg) { grid-area: text; } }
    &__visual { @include respond-to(lg) { grid-area: visual; align-self: center; } }
    &__stats  { @include respond-to(lg) { grid-area: stats; } }

    &__label {
      margin-bottom: 1.5rem;
    }

    &__title {
      font-family: $font-display;
      font-weight: 600;
      font-size: clamp(1.75rem, 4.5vw, 3.75rem);
      line-height: 1.15;
      color: $ink;
      margin-bottom: 1.75rem;
      letter-spacing: -0.01em;

      em {
        font-style: italic;
        color: $caramel;
        font-weight: 400;
      }
    }

    &__body-block {
      position: relative;
    }

    &__body {
      font-family: $font-body;
      font-size: clamp(0.875rem, 2vw, 1rem);
      line-height: 1.8;
      color: $charcoal;
      margin-bottom: 1.25rem;
      word-break: break-word;
      overflow-wrap: break-word;
    }

    // Cursor follows the text via CSS ::after on the active paragraph
    &__body--typing::after,
    &__body--done::after {
      content: '|';
      color: $caramel;
      font-weight: 300;
      margin-left: 1px;
      animation: cursor-blink 0.7s step-end infinite;
    }

    &__stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 2rem;
      padding-top: 2rem;
      border-top: 1px solid rgba($sienna, 0.15);
      text-align: left;

      @include respond-to(lg) {
        display: flex;
        flex-wrap: wrap;
        gap: 2.5rem;
        padding-top: 0;
        border-top: none;
      }
    }

    &__stat {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &__stat-number {
      font-family: $font-display;
      font-weight: 600;
      font-size: 2rem;
      color: $caramel;
      line-height: 1;

      // "Inglês" is text, not a number — scale down to fit the 2-col grid on mobile
      @media (max-width: #{$bp-lg - 1}) {
        font-size: clamp(1.5rem, 4vw, 2rem);
        text-align: center;
      }
    }

    &__stat-label {
      font-family: $font-body;
      font-size: 0.8125rem;
      color: $muted;

      @media (max-width: #{$bp-lg - 1}) {
        font-size: 0.75rem;
        text-align: center;
      }
    }

    &__visual {
      display: flex;
      justify-content: center;
      padding: 1rem 1rem 1.5rem;

      @include respond-to(lg) {
        padding: 0;
      }
    }

    &__photo-perspective {
      perspective: 900px;
      perspective-origin: 50% 40%;
    }

    &__photo-frame {
      position: relative;
      width: min(280px, 80vw);
      height: min(280px, 80vw);
      animation: coin-flip 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards,
                 levitate 4s ease-in-out 1.5s infinite;

      @include respond-to(sm) {
        width: 360px;
        height: 360px;
      }

      @include respond-to(lg) {
        width: 460px;
        height: 460px;
      }
    }

    &__photo-wrap {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      overflow: hidden;
      @include shadow-md;
    }

    &__photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      display: block;
    }

    &__photo-accent {
      position: absolute;
      bottom: -0.875rem;
      right: -0.875rem;
      width: 100%;
      height: 100%;
      border: 1.5px solid rgba($caramel, 0.25);
      border-radius: 50%;
      z-index: -1;

      @include respond-to(lg) {
        bottom: -1.25rem;
        right: -1.25rem;
      }
    }
  }

  @keyframes orb-drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(30px, 20px) scale(1.1); }
  }

  @keyframes coin-flip {
    0%   { transform: rotateY(0deg); }
    100% { transform: rotateY(720deg); }
  }

  @keyframes levitate {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-16px); }
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }
</style>
