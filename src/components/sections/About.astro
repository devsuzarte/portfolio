---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section id="about" class="about section" data-theme="light" data-scroll-section data-reveal-section>
  <div class="about__orb about__orb--1" aria-hidden="true"></div>
  <div class="about__orb about__orb--2" aria-hidden="true"></div>
  <div class="about__orb about__orb--3" aria-hidden="true"></div>
  <div class="container about__inner">
    <div class="about__text" data-reveal-item>
      <p class="about__label badge">Sobre mim</p>
      <h2 class="about__title heading-underline">
        Do design ao deploy,<br/>
        <em>com IA, Cloud e foco em resultado.</em>
      </h2>

      <div class="about__body-block">
        <p class="about__body" data-typewriter="1">Com mais de 4 anos no mercado, sou desenvolvedor Pleno atuando em empresas de grande porte como Ford e em projetos freelance próprios. Atuo também como professor particular de programação, o que me faz buscar sempre clareza técnica e evolução contínua.</p>
        <p class="about__body" data-typewriter="2">Programação é tanto minha profissão quanto meu hobby — me aprofundo especialmente em IA, Cloud e arquiteturas modernas. Tenho inglês intermediário-avançado, o que me permite trabalhar com documentações, equipes e clientes internacionais sem barreiras. Fora do computador, toco violão, canto e curto andar de bicicleta.</p>
        <span class="about__cursor" aria-hidden="true">|</span>
      </div>

      <div class="about__stats">
        <div class="about__stat">
          <span class="about__stat-number">4+</span>
          <span class="about__stat-label">Anos de experiência</span>
        </div>
        <div class="about__stat">
          <span class="about__stat-number">8+</span>
          <span class="about__stat-label">Projetos entregues</span>
        </div>
        <div class="about__stat">
          <span class="about__stat-number">100%</span>
          <span class="about__stat-label">Comprometimento</span>
        </div>
      </div>
    </div>

    <div class="about__visual" data-reveal-item>
      <div class="about__photo-perspective">
        <div class="about__photo-frame">
          <div class="about__photo-wrap">
            <img
              src={`${base}assets/images/projects/me.png`}
              alt="Foto de Benjamin Suzarte"
              class="about__photo"
              loading="lazy"
            />
          </div>
          <div class="about__photo-accent" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const els = Array.from(document.querySelectorAll<HTMLElement>('[data-typewriter]'));
    if (els.length === 0) return;

    const cursor = document.querySelector<HTMLElement>('.about__cursor');

    // Store trimmed texts and reserve natural height BEFORE clearing
    const texts = els.map(el => {
      const text = (el.textContent ?? '').trim().replace(/\s+/g, ' ');
      // Reserve height so layout doesn't jump
      const h = el.getBoundingClientRect().height || el.scrollHeight;
      if (h > 0) el.style.minHeight = h + 'px';
      el.textContent = '';
      return text;
    });

    // Cursor hidden until typing starts
    if (cursor) cursor.style.opacity = '0';

    const typeEl = (el: HTMLElement, text: string, cb: () => void) => {
      let i = 0;
      const tick = () => {
        el.textContent += text[i++];
        if (i < text.length) setTimeout(tick, 10);
        else cb();
      };
      setTimeout(tick, 10);
    };

    let started = false;
    const obs = new IntersectionObserver(entries => {
      if (started || !entries[0].isIntersecting) return;
      started = true;
      obs.disconnect();

      if (cursor) cursor.style.opacity = '1';

      const runSeq = (idx: number) => {
        if (idx >= els.length) return; // all done, cursor stays blinking
        typeEl(els[idx], texts[idx], () => runSeq(idx + 1));
      };
      runSeq(0);
    }, { threshold: 0.15 });

    obs.observe(els[0]);
  })();
</script>

<style lang="scss">
  @use '@/styles/tokens' as *;

  .about {
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;

    &__orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
      opacity: 0.35;
    }

    &__orb--1 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba($caramel, 0.5), transparent 70%);
      top: -10%;  left: -8%;
      animation: orb-drift 14s ease-in-out infinite alternate;
    }

    &__orb--2 {
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba($sienna, 0.4), transparent 70%);
      bottom: 5%;  right: 5%;
      animation: orb-drift 18s ease-in-out infinite alternate-reverse;
    }

    &__orb--3 {
      width: 200px; height: 200px;
      background: radial-gradient(circle, rgba($amber, 0.35), transparent 70%);
      top: 50%;  left: 55%;
      animation: orb-drift 11s ease-in-out infinite alternate;
    }

    &__inner {
      display: grid;
      grid-template-columns: 1fr;
      gap: 4rem;
      align-items: center;

      @include respond-to(lg) {
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
      }
    }

    &__label {
      margin-bottom: 1.5rem;
    }

    &__title {
      font-family: $font-display;
      font-weight: 300;
      font-size: clamp(2.25rem, 4.5vw, 3.75rem);
      line-height: 1.15;
      color: $ink;
      margin-bottom: 1.75rem;
      letter-spacing: -0.01em;

      em {
        font-style: italic;
        color: $caramel;
        font-weight: 400;
      }
    }

    &__body-block {
      position: relative;
    }

    &__body {
      font-family: $font-body;
      font-size: 1rem;
      line-height: 1.8;
      color: $charcoal;
      margin-bottom: 1.25rem;
    }

    &__cursor {
      display: inline-block;
      color: $caramel;
      animation: cursor-blink 0.7s step-end infinite;
      font-weight: 300;
      font-size: 1.1rem;
      line-height: 1;
      vertical-align: middle;
      margin-left: 1px;
    }

    &__stats {
      display: flex;
      gap: 2.5rem;
      margin-top: 2.5rem;
      padding-top: 2.5rem;
      border-top: 1px solid rgba($sienna, 0.15);
    }

    &__stat {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &__stat-number {
      font-family: $font-display;
      font-weight: 600;
      font-size: 2rem;
      color: $caramel;
      line-height: 1;
    }

    &__stat-label {
      font-family: $font-body;
      font-size: 0.8125rem;
      color: $muted;
    }

    &__visual {
      display: flex;
      justify-content: center;
    }

    &__photo-perspective {
      perspective: 900px;
      perspective-origin: 50% 40%;
    }

    &__photo-frame {
      position: relative;
      width: 360px;
      height: 360px;
      animation: coin-flip 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards,
                 levitate 4s ease-in-out 1.5s infinite;

      @include respond-to(lg) {
        width: 460px;
        height: 460px;
      }
    }

    &__photo-wrap {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      overflow: hidden;
      @include shadow-md;
      isolation: isolate;

      &::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba($caramel, 0.22);
        mix-blend-mode: color;
        pointer-events: none;
      }
    }

    &__photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      display: block;
      filter: sepia(0.15) saturate(1.25) brightness(0.97);
    }

    &__photo-accent {
      position: absolute;
      bottom: -1.25rem;
      right: -1.25rem;
      width: 100%;
      height: 100%;
      border: 1.5px solid rgba($caramel, 0.25);
      border-radius: 50%;
      z-index: -1;
    }
  }

  @keyframes orb-drift {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(30px, 20px) scale(1.1); }
  }

  @keyframes coin-flip {
    0%   { transform: rotateY(0deg); }
    100% { transform: rotateY(720deg); }
  }

  @keyframes levitate {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-16px); }
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }
</style>
