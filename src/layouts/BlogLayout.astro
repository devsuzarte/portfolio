---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/navigation/Header.astro';
import Footer from '@/components/navigation/Footer.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  author?: string;
  image?: string;
  readingTime?: number;
  tags?: string[];
}

const {
  title,
  description,
  pubDate,
  author = 'Juan Benjamin Almeida Suzarte',
  image,
  readingTime,
  tags = [],
} = Astro.props;

const formattedDate = pubDate
  ? pubDate.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<BaseLayout title={`${title} — Blog`} description={description}>
  <Header />

  <main class="blog-post" data-theme="dark">
    <article class="blog-post__article container">
      <header class="blog-post__header">
        <div class="blog-post__meta">
          {formattedDate && <time datetime={pubDate?.toISOString()}>{formattedDate}</time>}
          {readingTime && <span>{readingTime} min de leitura</span>}
        </div>

        <h1 class="blog-post__title">{title}</h1>

        {description && <p class="blog-post__description">{description}</p>}

        {tags.length > 0 && (
          <div class="blog-post__tags">
            {tags.map(tag => <span class="badge">{tag}</span>)}
          </div>
        )}

        {image && (
          <div class="blog-post__cover">
            <img src={image} alt={title} />
          </div>
        )}
      </header>

      <div class="blog-post__content prose">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style lang="scss">
  @use '@/styles/tokens' as *;

  .blog-post {
    padding-top: 6rem;
    min-height: 100vh;
    background: $espresso;

    &__article {
      max-width: 720px;
      margin: 0 auto;
      padding-top: 4rem;
      padding-bottom: 8rem;
    }

    &__header {
      margin-bottom: 3rem;
    }

    &__meta {
      display: flex;
      gap: 1.5rem;
      font-family: $font-code;
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: $muted;
      margin-bottom: 1.5rem;
    }

    &__title {
      font-family: $font-display;
      font-weight: 300;
      font-style: italic;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1.1;
      color: $cream;
      margin-bottom: 1.25rem;
    }

    &__description {
      font-family: $font-body;
      font-size: 1.125rem;
      line-height: 1.7;
      color: $latte;
      margin-bottom: 1.5rem;
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2rem;
    }

    &__cover {
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: 4px;
      margin-top: 2rem;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }
  }

  // Prose styles
  :global(.prose) {
    color: rgba($cream, 0.85);

    h2, h3, h4 {
      font-family: $font-display;
      color: $cream;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
    }

    h2 { font-size: 1.875rem; }
    h3 { font-size: 1.5rem; }

    p { margin-bottom: 1.5rem; line-height: 1.8; }

    a { color: $caramel; text-decoration: underline; text-underline-offset: 3px; }

    code {
      font-family: $font-code;
      font-size: 0.875rem;
      background: rgba($sienna, 0.2);
      color: $caramel;
      padding: 0.1em 0.4em;
      border-radius: 3px;
    }

    pre {
      background: $dark-roast;
      border: 1px solid rgba($caramel, 0.15);
      border-radius: 4px;
      padding: 1.5rem;
      overflow-x: auto;
      margin-bottom: 1.5rem;

      code {
        background: none;
        padding: 0;
        color: $oat;
      }
    }

    ul, ol {
      padding-left: 1.5rem;
      margin-bottom: 1.5rem;

      li { margin-bottom: 0.5rem; }
    }

    blockquote {
      border-left: 2px solid $caramel;
      padding-left: 1.5rem;
      color: $latte;
      font-style: italic;
      margin-bottom: 1.5rem;
    }

    img {
      border-radius: 4px;
      margin: 2rem 0;
    }
  }
</style>
